{
  "arcp_schema_version": "0.2",
  "component_type": "harness",
  "component_id": "agent-harness",
  "component_version": "1.3.9",
  "protocol_version": "0.2",
  "name": "Agent Harness",
  "description": "Reusable Python harness for bounded, inspectable, approval-gated, memory-governed agents.",
  "contracts": {
    "agent_manifest": "1.1",
    "run_request": "1.0",
    "interactive_run_control": "1.0",
    "run_events": "1.0",
    "artifacts": "1.0",
    "human_review": "1.0",
    "checkpoint_resume": "1.0",
    "cancellation": "1.0"
  },
  "capabilities": {
    "provides": [
      "llm.completion",
      "web.fetch",
      "checkpoint_resume",
      "cooperative_cancellation",
      "interactive_run_control",
      "human_review"
    ]
  },
  "tools": [
    "harness.llm.complete",
    "harness.web.fetch"
  ],
  "event_types": [
    "run.requested",
    "agent.manifest_loaded",
    "compatibility.checked",
    "policy.checked",
    "run.started",
    "llm.completion_requested",
    "llm.completion_allowed",
    "llm.completion_completed",
    "run.completed",
    "run.failed",
    "run.blocked",
    "run.cancelled",
    "review.approved",
    "review.changes_requested",
    "review.rejected",
    "artifact.registered",
    "checkpoint.created",
    "run.resumed"
  ],
  "constraints": {
    "secret_policy": "secret_ref_only",
    "human_review_supported": true
  },
  "checkpoint_resume": {
    "schema_version": "1.0",
    "resume_supported": true,
    "checkpoint_single_use": true
  },
  "cancellation": {
    "cooperative_cancellation": true,
    "cancellable_run_states": ["running", "pending_review"]
  },
  "events": {
    "schema_version": "1.0",
    "incremental_query": "event_polling",
    "ordering": "ordered"
  },
  "artifacts": {
    "schema_version": "1.0",
    "artifact_discovery": "registration",
    "artifact_available_before_completion": false
  },
  "human_review": {
    "schema_version": "1.0",
    "supported_actions": ["approve", "reject", "request_changes"],
    "review_discovery": "event",
    "review_decision_submission": "api"
  }
}

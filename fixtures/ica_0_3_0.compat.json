{
  "arcp_schema_version": "0.2",
  "component_type": "agent",
  "component_id": "information_collector_agent",
  "component_version": "0.3.0",
  "protocol_version": "0.2",
  "name": "Information Collector Agent v0.3.0",
  "description": "Interactive ICA — requires harness runtime, LLM completion, web fetch, events, artifacts, review gates and checkpoint/resume.",
  "requires": {
    "harness": ">=1.3.9,<1.4.0"
  },
  "contracts": {
    "agent_manifest": ">=1.1,<2.0",
    "interactive_run_control": ">=1.0,<2.0",
    "run_events": ">=1.0,<2.0",
    "artifacts": ">=1.0,<2.0",
    "human_review": ">=1.0,<2.0",
    "checkpoint_resume": ">=1.0,<2.0",
    "cancellation": ">=1.0,<2.0"
  },
  "capabilities": {
    "required": ["llm.completion", "web.fetch"],
    "optional": ["web.search", "web.crawl"]
  },
  "tools": ["harness.llm.complete", "harness.web.fetch"],
  "events": {
    "supported_types": [
      "run.requested",
      "agent.manifest_loaded",
      "run.started",
      "llm.completion_requested",
      "llm.completion_completed",
      "run.completed",
      "run.failed",
      "review.approved",
      "review.changes_requested",
      "review.rejected",
      "artifact.registered",
      "checkpoint.created",
      "run.resumed",
      "run.cancelled"
    ]
  },
  "llm_requirements": {
    "capabilities": ["llm.completion"],
    "minimum_context_window": 32000,
    "structured_output_required": true,
    "tool_calling_required": true,
    "streaming_optional": true
  },
  "artifacts": {
    "schema_version": "1.0",
    "renderer_hints": ["evidence_table", "source_cards"]
  },
  "human_review": {
    "schema_version": "1.0"
  },
  "checkpoint_resume": {
    "schema_version": "1.0"
  },
  "incompatibilities": []
}

      "harness.web.fetch"
    ],
    "events": {
      "supported_types": [
        "run.requested",
        "agent.manifest_loaded",
        "compatibility.checked",
        "run.started",
        "llm.completion_requested",
        "llm.completion_completed",
        "run.completed",
        "run.failed",
        "run.blocked",
        "run.cancelled",
        "review.approved",
        "review.changes_requested",
        "review.rejected",
        "artifact.registered",
        "checkpoint.created",
        "run.resumed"
      ]
    },
    "checkpoint_resume": {
      "schema_version": "1.0",
      "resume_supported": true,
      "checkpoint_single_use": true
    },
    "cancellation": {
      "cooperative_cancellation": true,
      "cancellable_run_states": [
        "running",
        "pending_review"
      ]
    },
    "human_review": {
      "schema_version": "1.0",
      "supported_actions": [
        "approve",
        "reject",
        "request_changes"
      ]
    }
  },

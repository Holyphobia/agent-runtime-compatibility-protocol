{
  "harness": {
    "arcp_schema_version": "0.2",
    "component_type": "harness",
    "component_id": "agent-harness",
    "component_version": "1.3.9",
    "protocol_version": "0.2",
    "name": "Agent Harness",
    "description": "Harness v1.3.9 with full interactive support",
    "contracts": {
      "agent_manifest": "1.1",
      "run_request": "1.0",
      "interactive_run_control": "1.0",
      "run_events": "1.0",
      "artifacts": "1.0",
      "human_review": "1.0",
      "checkpoint_resume": "1.0",
      "cancellation": "1.0"
    },
    "capabilities": {

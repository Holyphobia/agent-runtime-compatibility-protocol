    },
    "capabilities": {
      "provides": ["llm.completion"]
    },
    "events": {
      "supported_types": ["run.requested", "run.started", "run.completed"]
    }
  },
  "agent": {
    "arcp_schema_version": "0.2",
    "component_type": "agent",
    "component_id": "information_collector_agent",
    "component_version": "0.2.0",
    "protocol_version": "0.2",
    "name": "Information Collector Agent v0.2.0",

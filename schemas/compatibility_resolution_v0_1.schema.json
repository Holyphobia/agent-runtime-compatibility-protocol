{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ARCP Compatibility Resolution",
  "description": "Schema for ARCP 0.1 compatibility resolution output",
  "type": "object",
  "required": ["arcp_schema_version", "compatible", "decision", "resolved_versions", "matched", "warnings", "blockers"],
  "properties": {
    "arcp_schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "compatible": { "type": "boolean" },
    "decision": {
      "type": "string",
      "enum": ["allowed", "blocked"]
    },
    "resolved_versions": {
      "type": "object",
      "properties": {
        "harness": { "type": "string" },
        "beta": { "type": "string" },
        "agent": { "type": "string" }
      },
      "required": ["harness", "beta", "agent"]
    },
    "matched": {
      "type": "object",
      "properties": {
        "tools": { "type": "array", "items": { "type": "string" } },
        "capabilities": { "type": "array", "items": { "type": "string" } },
        "contracts": { "type": "object" }
      }
    },
    "warnings": { "type": "array" },
    "blockers": { "type": "array" },
    "suggested_actions": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
